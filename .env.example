# =============================================================================
# LISM - Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# NEVER commit .env.local or any file containing real secrets to version control.
# All variables marked [REQUIRED] must be set for the application to function.
# Variables marked [OPTIONAL] have fallback behavior when not set.
# =============================================================================


# =============================================================================
# DATABASE
# =============================================================================
# [REQUIRED] PostgreSQL connection string (Neon serverless recommended).
# Format: postgres://user:password@host/database?sslmode=require
# Get this from your Neon project dashboard: https://console.neon.tech
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# [OPTIONAL] Non-pooled connection string, used only by scripts/run-migrations.mjs
# (DDL should not go through a connection pooler). Falls back to DATABASE_URL
# if not set. On Neon this is the "direct" host (no "-pooler" suffix).
DIRECT_URL=postgres://user:password@host/database?sslmode=require

# [OPTIONAL] Which driver lib/db.ts uses to talk to PostgreSQL.
# "neon" (default, omit this var) uses @neondatabase/serverless (HTTP protocol,
# Neon-only). "azure_postgresql" uses `pg` (standard wire protocol), required
# when DATABASE_URL points at Azure Database for PostgreSQL Flexible Server or
# any non-Neon Postgres. Set by Terraform in lism-infra based on database_mode —
# see lism-infra/docs/environment-variables.md.
DATABASE_DRIVER=neon

# [OPTIONAL, local only] Set to "true" to disable TLS for the `pg` driver
# against a local/dev Postgres without SSL. NEVER set this in staging/production
# (Azure Postgres and Neon both require TLS). Deliberately not named PGSSLMODE —
# `pg` reads that env var natively too and the two can collide confusingly.
LISM_DB_SSL_DISABLE=

# [OPTIONAL] Azure Blob Storage for user avatars and institution logos
# (lib/blob-storage.ts). Set by Terraform in lism-infra (module.storage /
# module.identities outputs) — see lism-infra/docs/environment-variables.md.
# If AZURE_STORAGE_ACCOUNT_URL is not set, avatar/logo upload endpoints
# respond with a clear 503 instead of crashing; the rest of the app is
# unaffected. Authentication is via Managed Identity only (no access keys,
# no connection strings) — AZURE_CLIENT_ID is the client ID of the app's
# user-assigned identity, needed so DefaultAzureCredential picks the right
# one in environments with multiple identities.
AZURE_STORAGE_ACCOUNT_URL=
AZURE_STORAGE_FILES_CONTAINER=lism-files
AZURE_CLIENT_ID=


# =============================================================================
# SESSION / AUTH
# =============================================================================
# [REQUIRED] Secret key used to sign and verify session cookies.
# Must be at least 32 characters long. Generate with:
#   openssl rand -base64 32
# SECURITY: Never reuse this value across environments.
SESSION_SECRET=change-this-to-a-random-secret-minimum-32-chars

# [OPTIONAL] Secret used to sign QR temporary access codes (lib/qr-security.ts).
# Falls back to SESSION_SECRET, then to an insecure demo default, if unset —
# set this explicitly before handling real QR-protected resources.
# Generate with: openssl rand -base64 32
QR_ACCESS_SECRET=change-this-to-a-different-random-secret-minimum-32-chars


# =============================================================================
# DEPLOYMENT (Azure Container Apps — see lism-infra/)
# =============================================================================
# [OPTIONAL] These are set automatically by Terraform/Container Apps in
# staging and production. Only needed locally if you're testing the Docker
# image directly (docker run) instead of `npm run dev`.
PORT=3000
DEMO_MODE=false
APP_URL=http://localhost:3000
# En producción, usa el dominio real (https://nexalab.com): también alimenta
# metadataBase, robots.txt y sitemap.xml (ver app/layout.tsx, app/robots.ts,
# app/sitemap.ts).
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NexaLab LIS


# =============================================================================
# RECURRENTE PAYMENT API
# Backend only — NEVER expose these values to the frontend or client-side code.
# Docs: https://docs.recurrente.com
# =============================================================================

# [REQUIRED for billing] Your Recurrente secret API key.
# Found in your Recurrente dashboard under API Settings.
# Use sk_live_* for production and sk_test_* for testing.
RECURRENTE_SECRET_KEY=replace-with-your-sk_live-or-sk_test-key

# [REQUIRED for billing] Webhook signing secret issued by Recurrente when you
# register your webhook endpoint in the dashboard.
# Format: whsec_<base64-encoded-secret>
# Used to verify that incoming webhook payloads are authentic (via Svix HMAC-SHA256).
RECURRENTE_WEBHOOK_SIGNING_SECRET=replace-with-your-whsec-signing-secret

# [OPTIONAL] Base URL for the Recurrente API.
# Defaults to https://app.recurrente.com/api if not set.
# Override only if Recurrente provides a different endpoint (e.g., sandbox).
RECURRENTE_API_BASE_URL=https://app.recurrente.com/api


# =============================================================================
# RECURRENTE CHECKOUT REDIRECT URLs
# These must be publicly accessible URLs on your production domain.
# For local development, use a tunneling tool such as ngrok or cloudflared.
# =============================================================================

# [REQUIRED for billing] URL Recurrente redirects to after a successful checkout.
RECURRENTE_SUCCESS_URL=https://yourdomain.com/app/billing?checkout=success

# [REQUIRED for billing] URL Recurrente redirects to when the user cancels checkout.
RECURRENTE_CANCEL_URL=https://yourdomain.com/app/billing?checkout=canceled

# [REQUIRED for billing] Public URL of your webhook handler endpoint.
# Register this exact URL in the Recurrente dashboard to receive payment events.
# Handled by: app/api/webhooks/recurrente/route.ts
# Events received: payment_intent.succeeded, subscription.created,
#   subscription.cancelled, subscription.updated, payment.completed, payment.failed
RECURRENTE_WEBHOOK_URL=https://yourdomain.com/api/webhooks/recurrente


# =============================================================================
# RECURRENTE PLAN PRODUCT / PRICE IDs
# [OPTIONAL] Set these after creating your subscription products in the
# Recurrente dashboard. When a Price ID is provided, checkout sessions will
# reference the pre-configured price instead of sending inline item details.
# If left empty, the billing module falls back to inline items using
# charge_type: "recurring" with the plan's amount_in_cents.
#
# Plans:
#   academic_starter  — Academic Starter  — USD 59/month  — up to  5 users, 1 lab
#   professional      — Professional      — USD 189/month — up to 12 users, 1 lab
#   multi_site        — Multi-site        — USD 549/month — up to 30 users, 3 labs
# =============================================================================

# Academic Starter plan (USD 59/month)
RECURRENTE_PLAN_ACADEMIC_STARTER_PRODUCT_ID=
RECURRENTE_PLAN_ACADEMIC_STARTER_PRICE_ID=

# Professional plan (USD 189/month)
RECURRENTE_PLAN_PROFESSIONAL_PRODUCT_ID=
RECURRENTE_PLAN_PROFESSIONAL_PRICE_ID=

# Multi-site plan (USD 549/month)
RECURRENTE_PLAN_MULTI_SITE_PRODUCT_ID=
RECURRENTE_PLAN_MULTI_SITE_PRICE_ID=
